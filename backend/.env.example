# ─────────────────────────────────────────────────────────────────────
# Aura Net Backend – Environment Variables
# Copy this file to .env for local dev.
# In Railway: set every variable in the "Variables" tab of your service.
# ─────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── MongoDB (Railway) ─────────────────────────────────────────────────
# Railway injects MONGODB_URL automatically when you add the MongoDB plugin.
# It looks like:  mongodb://mongo:PASSWORD@containers-us-west-XXX.railway.app:PORT/railway
# Just reference it as MONGODB_URL — no changes needed on Railway.
MONGODB_URL=mongodb://localhost:27017/auranet

# ── JWT ───────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_HEX_64
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_RANDOM_HEX_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── BMS Credentials (default — users can override in Settings) ────────
BMS_URL=https://bms.libatech.net.lb
BMS_USER=nasri
BMS_PASS=your_bms_password

# ── Auto-sync schedule (cron) ─────────────────────────────────────────
# Every 15 min:  */15 * * * *
# Every hour:    0 * * * *
# Every 6 hours: 0 */6 * * *
SYNC_CRON=0 * * * *

# ── CORS ──────────────────────────────────────────────────────────────
FRONTEND_URL=https://auranet.vercel.app
